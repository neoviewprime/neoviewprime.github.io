HOST=0.0.0.0
PORT=3390
NODE_ENV=development

JWT_SECRET=change-me
JWT_EXPIRES_IN=7d
CLIENT_URL=http://localhost:3389

DB_PROVIDER=sqlite
DB_CLIENT=sqlite
SQLITE_PATH=data/neoview.sqlite
DATABASE_URL="file:./data/neoview.sqlite"

DB_SCHEMA=neoview_schema

# Choose one vector backend:
VECTOR_PROVIDER=sqlite
# VECTOR_PROVIDER=chromadb

# Required only when VECTOR_PROVIDER=chromadb
# CHROMA_URL=http://localhost:8000
# CHROMA_TENANT=default_tenant
# CHROMA_DATABASE=default_database
# CHROMA_REPORT_COLLECTION=reports_chunks
# CHROMA_CACHE_COLLECTION=semantic_cache

LLM_PROVIDER=auto
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=phi3:mini

EMBEDDING_PROVIDER=local
OPENAI_EMBED_MODEL=text-embedding-3-small
OPENAI_CHAT_MODEL=gpt-4o-mini
# OPENAI_API_KEY=
